# ===========================================
# NanAgi 环境变量模板
# 复制此文件为 .env.local 并填入真实值
# ===========================================
#
# cp .env.example .env.local
#
# 密码 hash 生成方式：
#   node -e "const bcrypt = require('bcryptjs'); console.log(bcrypt.hashSync('你的密码', 10));"
#
# DeepSeek API Key 获取：
#   https://platform.deepseek.com/api_keys
#
# ===========================================

# 登录密码的 bcrypt hash（10轮salt）
NANAGI_PASSWORD_HASH=your_bcrypt_hash_here

# DeepSeek API Key（Anthropic兼容端点）
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# 腾讯混元生图 API Key（hy-image-v3.0）
# 获取：https://tokenhub.tencentmaas.com
HUNYUAN_API_KEY=sk-your_hunyuan_api_key_here
HUNYUAN_KEY_ID=ak-your_hunyuan_key_id_here

# 和风天气 API（实时天气 + 环境感知自动调用）
# API Key: 控制台-凭据管理中获取
# API Host: 控制台-设置中查看 (每个项目独立Host)
# 获取: https://dev.qweather.com/
WEATHER_API_KEY=your_qweather_key_here
WEATHER_API_HOST=https://your_host.qweatherapi.com/v7/weather/now

# SMTP 邮件服务（邮箱验证码发送）
# QQ邮箱: smtp.qq.com, 端口465, 在QQ邮箱设置中开启SMTP并获取授权码
# 163邮箱: smtp.163.com, 端口465
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_authorization_code
SMTP_FROM=your_email@qq.com

# 注意: SEARCH_API_KEY 等其他 Key 请参考 lib/env.ts 按需添加
